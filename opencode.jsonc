{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "vector-mcp": {
      "type": "local",
      "command": [
        "env",
        "DENO_DIR=.deno",
        "DATABASE_URL=./data/knowledge.db",
        "VECTOR_MCP_CONFIG=./config.json",
        "deno",
        "run",
        "-A",
        "main.ts"
      ],
      "enabled": true
    }
  }
}